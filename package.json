{
  "name": "icf-portfolio",
  "productName": "ICF Creative Portfolio",
  "version": "0.5.1",
  "description": "Browse ICF Next's creative work from your local Box mount",
  "main": "main.js",
  "author": "Alex Gordon, ICF Next",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alexthebrit/icf-portfolio-releases.git"
  },
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE node ./node_modules/electron/cli.js . --dev",
    "start": "env -u ELECTRON_RUN_AS_NODE node ./node_modules/electron/cli.js .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-store": "^7.0.3",
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.icfnext.portfolio",
    "productName": "ICF Creative Portfolio",
    "afterSign": "scripts/notarize.js",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "ICF-Creative-Portfolio-${version}-${arch}.${ext}",
      "identity": "E3C6B97B885843868879D7360252DE1E1EAF732E",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ICF Creative Portfolio",
      "artifactName": "ICF-Creative-Portfolio-${version}-Setup.${ext}"
    },
    "dmg": {
      "title": "ICF Creative Portfolio",
      "artifactName": "ICF-Creative-Portfolio-${version}-${arch}.${ext}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "*.js",
      "*.json",
      "*.html",
      "assets/**/*",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp}",
      "!**/._*",
      "!**/.DS_Store"
    ],
    "extraResources": [
      {
        "from": "py-scripts",
        "to": "py-scripts",
        "filter": ["**/*.py"]
      },
      {
        "from": "scripts/sync-to-s3.sh",
        "to": "scripts/sync-to-s3.sh"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Alexthebrit",
      "repo": "icf-portfolio-releases"
    },
    "asar": true
  }
}
